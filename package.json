{
  "name": "nesting-app",
  "version": "1.1.0",
  "description": "DXF Nesting Application",
  "author": "Kenzap Pte Ltd",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "preflight:mac-helpers": "node scripts/verify-mac-helpers.js",
    "preflight:win-helpers": "node scripts/verify-win-helpers.js",
    "preflight:appx-host": "node scripts/verify-appx-host.js",
    "appx:upload": "node scripts/make-appxupload.js",
    "install:appx-test": "powershell -ExecutionPolicy Bypass -File scripts/install-appx-test-package.ps1",
    "verify:mas-signing": "node scripts/verify-mas-signing.js",
    "dist:mac": "npm run preflight:mac-helpers && electron-builder --mac dmg zip",
    "dist:mas": "npm run preflight:mac-helpers && electron-builder --mac mas",
    "dist:mas-dev": "npm run preflight:mac-helpers && electron-builder --mac mas-dev",
    "dist:win": "npm run preflight:win-helpers && electron-builder --win nsis",
    "dist:win-portable": "npm run preflight:win-helpers && electron-builder --win portable",
    "dist:appx": "npm run preflight:win-helpers && npm run preflight:appx-host && electron-builder --win appx --x64 && npm run appx:upload"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@flatten-js/core": "^1.6.12",
    "concaveman": "^2.0.0",
    "dxf-parser": "^1.1.2",
    "jsts": "^2.12.1",
    "makerjs": "^0.18.2",
    "planar-face-discovery": "^2.0.7",
    "to-planar-graph": "^3.0.1"
  },
  "build": {
    "appId": "com.kenzap.nesting",
    "appxManifestCreated": "scripts/patch-appx-manifest.js",
    "productName": "Kenzap Nesting",
    "files": [
      "main.js",
      "main/**/*",
      "preload.js",
      "package.json",
      "renderer/**/*",
      "shared/**/*",
      "assets/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "extraResources": [
        {
          "from": "native/windows",
          "to": "native/windows",
          "filter": [
            "**/*"
          ]
        }
      ],
      "icon": "assets/icon-square.ico",
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "mac": {
      "extraFiles": [
        {
          "from": "native/macos/bin",
          "to": "Helpers",
          "filter": [
            "sparrow",
            "dxf_preprocess"
          ]
        }
      ],
      "binaries": [
        "Contents/Helpers/sparrow",
        "Contents/Helpers/dxf_preprocess"
      ],
      "icon": "assets/icon-square.icns"
    },
    "mas": {
      "type": "distribution",
      "entitlements": "build/entitlements.mas.plist",
      "entitlementsInherit": "build/entitlements.mas.inherit.plist"
    },
    "masDev": {
      "type": "development",
      "entitlements": "build/entitlements.mas.plist",
      "entitlementsInherit": "build/entitlements.mas.inherit.plist"
    },
    "appx": {
      "applicationId": "KenzapNesting",
      "identityName": "KenzapPteLtd.KenzapNesting",
      "publisher": "CN=8DBD4E24-DD06-4AEF-88B7-7F0C2E30B4D9",
      "publisherDisplayName": "Kenzap Pte Ltd",
      "displayName": "Kenzap Nesting",
      "backgroundColor": "#111827",
      "showNameOnTiles": false,
      "languages": [
        "en-US"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
